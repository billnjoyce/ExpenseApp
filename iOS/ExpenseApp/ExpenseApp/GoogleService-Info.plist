<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  ⚠️  이 파일은 플레이스홀더입니다.
  Firebase Console에서 실제 파일을 다운로드하여 교체하세요.

  설정 방법:
  1. Firebase Console (console.firebase.google.com) 접속
  2. 프로젝트 선택 또는 생성
  3. 프로젝트 설정 → iOS 앱 추가
  4. Bundle ID: com.example.ExpenseApp 입력
  5. GoogleService-Info.plist 다운로드
  6. 이 파일을 교체 (Xcode에서 드래그앤드롭, "Copy items if needed" 체크)
  7. Firebase Console → Authentication → Google 로그인 활성화
  8. Firestore Database → 데이터베이스 만들기
  9. Info.plist에 REVERSED_CLIENT_ID 추가 (URL Scheme)
-->
<plist version="1.0">
<dict>
  <key>CLIENT_ID</key>
  <string>YOUR_CLIENT_ID.apps.googleusercontent.com</string>
  <key>REVERSED_CLIENT_ID</key>
  <string>com.googleusercontent.apps.YOUR_CLIENT_ID</string>
  <key>API_KEY</key>
  <string>YOUR_API_KEY</string>
  <key>GCM_SENDER_ID</key>
  <string>YOUR_PROJECT_NUMBER</string>
  <key>PLIST_VERSION</key>
  <string>1</string>
  <key>BUNDLE_ID</key>
  <string>com.example.ExpenseApp</string>
  <key>PROJECT_ID</key>
  <string>YOUR_PROJECT_ID</string>
  <key>STORAGE_BUCKET</key>
  <string>YOUR_PROJECT_ID.appspot.com</string>
  <key>IS_ADS_ENABLED</key>
  <false/>
  <key>IS_ANALYTICS_ENABLED</key>
  <false/>
  <key>IS_APPINVITE_ENABLED</key>
  <true/>
  <key>IS_GCM_ENABLED</key>
  <true/>
  <key>IS_SIGNIN_ENABLED</key>
  <true/>
  <key>GOOGLE_APP_ID</key>
  <string>1:YOUR_PROJECT_NUMBER:ios:YOUR_APP_ID</string>
</dict>
</plist>
